# LeadGen API Environment Variables

# Server
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=*

# Database (file-based SQLite for MVP)
DATABASE_URL=./leadgen.db

# SerpAPI — Google Maps scraping (legacy, migrating to Outscraper)
SERPAPI_KEY=***

# Outscraper — Google Maps search + contact enrichment
OUTSCRAPER_API_KEY=***

# OpenRouter — AI email generation (Qwen model)
OPENROUTER_API_KEY=your_o...here

# Optional: Frontend URL for CORS (production)
# CORS_ORIGIN=https://app.leadgen.example.com

# Inbound Reply Webhook
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key
INBOUND_REPLY_DOMAIN=your-inbound-reply-domain

# Inngest
INNGEST_EVENT_KEY=***
INNGEST_SIGNING_KEY=***

# Stripe
STRIPE_SECRET_KEY=***
STRIPE_WEBHOOK_SECRET=whsec_***
STRIPE_PRICE_OUTREACH_MONTHLY=price_***
STRIPE_PRICE_OUTREACH_ANNUAL=price_***
STRIPE_PRICE_GROWTH_MONTHLY=price_***
STRIPE_PRICE_GROWTH_ANNUAL=price_***
STRIPE_PRICE_CREDITS_100=price_***
STRIPE_PRICE_CREDITS_500=price_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_***
