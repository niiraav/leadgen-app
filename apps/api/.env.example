# LeadGen API Environment Variables

# Server
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=*

# Database (file-based SQLite for MVP)
DATABASE_URL=./leadgen.db

# SerpAPI — Google Maps scraping
SERPAPI_KEY=your_serpapi_key_here

# OpenRouter — AI email generation (Qwen model)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Frontend URL for CORS (production)
# CORS_ORIGIN=https://app.leadgen.example.com
